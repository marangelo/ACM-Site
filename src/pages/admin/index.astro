---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getGalleries } from '../../lib/gallery';
import { validateSession } from '../../lib/auth';
import 'datatables.net-dt/css/dataTables.dataTables.css';

const token = Astro.cookies.get('session')?.value;
const isValid = await validateSession(token);

if (!isValid) {
  return Astro.redirect('/admin/login');
}

const galleries = await getGalleries();
const message = Astro.url.searchParams.get('message');
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="Dashboard - ACM Admin">
  <div class="dashboard-header">
    <div>
      <h1 class="page-title" style="margin-bottom:4px">Galerías</h1>
      <p class="dashboard-sub">Gestiona las galerías de fotos del colegio</p>
    </div>
    <a href="/admin/new" class="btn btn-primary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Nueva Galería
    </a>
  </div>

  {message && <div class="message message-success">{message}</div>}
  {error && <div class="message message-error">{error}</div>}

  {galleries.length > 0 ? (
    <table id="galleries-table" class="display" style="width:100%">
      <thead>
        <tr>
          <th>Galería</th>
          <th>Fecha</th>
          <th>Fotos</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {galleries.map(g => {
          const formatDate = new Date(g.date).toLocaleDateString('es-ES', {
            year: 'numeric', month: 'short', day: 'numeric'
          });
          return (
            <tr>
              <td><span class="row-title">{g.title}</span></td>
              <td>{formatDate}</td>
              <td><span class="count-badge">{g.images.length}</span></td>
              <td>
                <a href={`/admin/gallery/${g.slug}`} class="btn btn-sm btn-secondary">Gestionar</a>
                <form method="POST" action={`/api/galleries/${g.slug}/delete`} style="display:inline" class="delete-form">
                  <button type="submit" class="btn btn-sm btn-delete">Eliminar</button>
                </form>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  ) : (
    <div class="empty-state" style="padding:80px 20px">
      <div class="empty-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
      <h2>No hay galerías aún</h2>
      <p>Crea tu primera galería de fotos para comenzar.</p>
      <a href="/admin/new" class="btn btn-primary">Crear Galería</a>
    </div>
  )}
</AdminLayout>

<style>
  .dashboard-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .dashboard-sub {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  #galleries-table {
    background: var(--bg-card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  #galleries-table thead th {
    background: var(--primary) !important;
    color: var(--text-on-primary) !important;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 16px 24px;
    border-bottom: none;
  }
  #galleries-table tbody td {
    padding: 14px 24px;
    font-size: 0.93rem;
    border-bottom: 1px solid var(--border-light);
  }
  #galleries-table tbody tr:hover {
    background: #f8f8fc;
  }
  #galleries-table tbody tr:last-child td {
    border-bottom: none;
  }
  .row-title { font-weight: 600; }

  .count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    background: var(--secondary-glow);
    color: var(--secondary-dark);
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0 8px;
  }

  .btn-delete {
    background: transparent;
    border: 1px solid #e8a0a0;
    color: #c0392b;
    padding: 8px 14px;
    border-radius: var(--radius-xs);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition);
    margin-left: 8px;
  }
  .btn-delete:hover {
    background: #c0392b;
    color: white;
    border-color: #c0392b;
  }

  .empty-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    color: var(--text-muted);
  }

  :global(.dt-paging nav) {
    font-size: 0.9rem;
  }
  :global(.dt-paging button) {
    border: 1px solid var(--border) !important;
    border-radius: var(--radius-xs) !important;
    padding: 4px 12px !important;
    font-size: 0.85rem !important;
    margin: 0 2px !important;
  }
  :global(.dt-paging button.dt-paging-button.current) {
    background: var(--primary) !important;
    color: var(--text-on-primary) !important;
    border-color: var(--primary) !important;
  }
</style>

<script>
  import $ from 'jquery';
  import DataTable from 'datatables.net';
  import Swal from 'sweetalert2';

  const table = new DataTable('#galleries-table', {
    searching: false,
    lengthChange: false,
    language: {
      processing: 'Procesando...',
      lengthMenu: 'Mostrar _MENU_ registros',
      zeroRecords: 'No se encontraron resultados',
      emptyTable: 'Ningún dato disponible en esta tabla',
      info: 'Mostrando registros del _START_ al _END_ de un total de _TOTAL_ registros',
      infoEmpty: 'Mostrando registros del 0 al 0 de un total de 0 registros',
      infoFiltered: '(filtrado de un total de _MAX_ registros)',
      search: 'Buscar:',
      loadingRecords: 'Cargando...',
      paginate: {
        first: 'Primero',
        last: 'Último',
        next: 'Siguiente',
        previous: 'Anterior',
      },
    },
    order: [[1, 'desc']],
    pageLength: 10,
    lengthMenu: [5, 10, 25, 50],
  });

  document.addEventListener('submit', (e) => {
    const form = e.target.closest('.delete-form');
    if (!form) return;
    e.preventDefault();

    Swal.fire({
      title: '¿Eliminar galería?',
      text: 'Esta acción no se puede deshacer.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Sí, eliminar',
      cancelButtonText: 'Cancelar',
    }).then((result) => {
      if (result.isConfirmed) {
        form.submit();
      }
    });
  });
</script>
