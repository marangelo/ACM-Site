---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getGalleries } from '../../lib/gallery';
import { validateSession } from '../../lib/auth';

const token = Astro.cookies.get('session')?.value;
const isValid = await validateSession(token);

if (!isValid) {
  return Astro.redirect('/admin/login');
}

const galleries = await getGalleries();
const message = Astro.url.searchParams.get('message');
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="Dashboard - ACM Admin">
  <div class="dashboard-header">
    <div>
      <h1 class="page-title" style="margin-bottom:4px">Panel de Administración</h1>
      <p class="dashboard-sub">Gestiona las galerías de fotos del colegio</p>
    </div>
    <a href="/admin/new" class="btn btn-primary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Nueva Galería
    </a>
  </div>

  {message && <div class="message message-success">{message}</div>}
  {error && <div class="message message-error">{error}</div>}

  {galleries.length > 0 ? (
    <div class="admin-table">
      <div class="table-header">
        <span class="col-title">Galería</span>
        <span class="col-date">Fecha</span>
        <span class="col-count">Fotos</span>
        <span class="col-actions">Acciones</span>
      </div>
      {galleries.map(g => {
        const formatDate = new Date(g.date).toLocaleDateString('es-ES', {
          year: 'numeric', month: 'short', day: 'numeric'
        });
        return (
          <div class="table-row">
            <span class="col-title">
              <span class="row-title">{g.title}</span>
            </span>
            <span class="col-date">{formatDate}</span>
            <span class="col-count">
              <span class="count-badge">{g.images.length}</span>
            </span>
            <span class="col-actions">
              <a href={`/admin/gallery/${g.slug}`} class="btn btn-sm btn-secondary">Gestionar</a>
              <form method="POST" action={`/api/galleries/${g.slug}/delete`} style="display:inline" onsubmit="return confirm('¿Eliminar esta galería y todas sus fotos? Esta acción no se puede deshacer.')">
                <button type="submit" class="btn btn-sm btn-delete">Eliminar</button>
              </form>
            </span>
          </div>
        );
      })}
    </div>
  ) : (
    <div class="empty-state" style="padding:80px 20px">
      <div class="empty-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
      <h2>No hay galerías aún</h2>
      <p>Crea tu primera galería de fotos para comenzar.</p>
      <a href="/admin/new" class="btn btn-primary">Crear Galería</a>
    </div>
  )}
</AdminLayout>

<style>
  .dashboard-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .dashboard-sub {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .admin-table {
    background: var(--bg-card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .table-header, .table-row {
    display: grid;
    grid-template-columns: 2fr 1fr 80px 180px;
    align-items: center;
    padding: 16px 24px;
    gap: 12px;
  }
  .table-header {
    background: var(--primary);
    color: var(--text-on-primary);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .table-row {
    border-bottom: 1px solid var(--border-light);
    font-size: 0.93rem;
    transition: background var(--transition);
  }
  .table-row:last-child { border-bottom: none; }
  .table-row:hover { background: #f8f8fc; }
  .row-title { font-weight: 600; }

  .count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    background: var(--secondary-glow);
    color: var(--secondary-dark);
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0 8px;
  }

  .col-actions {
    display: flex;
    gap: 8px;
  }

  .btn-delete {
    background: transparent;
    border: 1px solid #e8a0a0;
    color: #c0392b;
    padding: 8px 14px;
    border-radius: var(--radius-xs);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition);
  }
  .btn-delete:hover {
    background: #c0392b;
    color: white;
    border-color: #c0392b;
  }

  .empty-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .table-header { display: none; }
    .table-row {
      grid-template-columns: 1fr;
      padding: 16px 20px;
      gap: 8px;
    }
    .col-date, .col-count { font-size: 0.85rem; color: var(--text-secondary); }
  }
</style>
