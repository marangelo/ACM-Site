---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { validateSession } from '../../lib/auth';

const token = Astro.cookies.get('session')?.value;
const isValid = await validateSession(token);

if (!isValid) {
  return Astro.redirect('/admin/login');
}

const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="Nueva Galería - ACM Admin">
  <a href="/admin" class="back-link">&larr; Volver al dashboard</a>

  <h1 class="page-title">Nueva Galería</h1>

  {error && <div class="message message-error">{error}</div>}

  <div class="form-card">
    <form method="POST" action="/api/galleries" class="form">
      <div class="form-row">
        <div class="form-group">
          <label for="title">Título del evento</label>
          <input type="text" id="title" name="title" class="form-input" required placeholder="Ej: Día del Niño 2026" />
        </div>

        <div class="form-group date-group">
          <label for="date">Fecha del evento</label>
          <div class="date-input-wrapper">
            <input type="text" id="date" name="date" class="form-input" required placeholder="Seleccionar fecha..." readonly />
            <svg class="calendar-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label for="description">Descripción (opcional)</label>
        <textarea id="description" name="description" class="form-input" placeholder="Describe brevemente el evento..."></textarea>
      </div>

      <button type="submit" class="btn btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Crear Galería
      </button>
    </form>
  </div>
</AdminLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    flatpickr('#date', {
      locale: 'es',
      dateFormat: 'Y-m-d',
      altFormat: 'j \\d\\e F \\d\\e Y',
      altInput: true,
      altInputClass: 'form-input date-alt-input',
      allowInput: false,
      disableMobile: true,
    });
  });
</script>

<style>
  .form-card {
    width: auto;
    border-radius: 0;
    background: var(--bg-card);
    box-shadow: var(--shadow);
    padding: 36px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
  }

  .date-input-wrapper {
    position: relative;
  }

  .date-input-wrapper .form-input {
    padding-right: 44px;
    cursor: pointer;
    background: var(--bg-card);
  }

  .calendar-icon {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  .flatpickr-calendar {
    border-radius: var(--radius-sm) !important;
    box-shadow: var(--shadow-lg) !important;
    border: 1px solid var(--border) !important;
    margin-top: 4px;
  }

  .flatpickr-months {
    background: var(--primary) !important;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0 !important;
    padding: 8px 0 !important;
  }

  .flatpickr-months .flatpickr-month,
  .flatpickr-current-month,
  .flatpickr-prev-month, .flatpickr-next-month {
    background: transparent !important;
  }

  .flatpickr-months .flatpickr-prev-month, 
  .flatpickr-months .flatpickr-next-month {
    fill: rgba(255,255,255,0.8) !important;
  }
  .flatpickr-months .flatpickr-prev-month:hover, 
  .flatpickr-months .flatpickr-next-month:hover {
    fill: #fff !important;
  }

  .flatpickr-current-month input.cur-year,
  .flatpickr-current-month .flatpickr-monthDropdown-months {
    color: #fff !important;
    font-weight: 700 !important;
  }

  .flatpickr-weekdays {
    background: var(--bg-section) !important;
  }

  .flatpickr-weekday {
    color: var(--text-secondary) !important;
    font-weight: 700 !important;
    font-size: 0.78rem !important;
  }

  .flatpickr-day.selected,
  .flatpickr-day.startRange,
  .flatpickr-day.endRange,
  .flatpickr-day.selected.inRange,
  .flatpickr-day.startRange.inRange,
  .flatpickr-day.endRange.inRange,
  .flatpickr-day:focus,
  .flatpickr-day:hover {
    background: var(--primary) !important;
    border-color: var(--primary) !important;
  }

  .flatpickr-day.today {
    border-color: var(--primary) !important;
  }

  .flatpickr-day.today.selected {
    background: var(--primary) !important;
    border-color: var(--primary) !important;
  }

  .flatpickr-day.inRange {
    background: var(--primary-glow) !important;
    border-color: transparent !important;
    box-shadow: none !important;
  }

  .flatpickr-months .flatpickr-prev-month svg,
  .flatpickr-months .flatpickr-next-month svg {
    width: 11px !important;
    height: 11px !important;
  }

  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
    }
    .form-card {
      padding: 24px 20px;
    }
  }
</style>
