---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppBtn from '../components/WhatsAppBtn.astro';
---

<BaseLayout title="Nuestra Academia - ACM" description="Conoce la historia, misión, visión y valores de la Academia Cristiana Maranatha en Nicaragua.">
  <section class="page-hero">
    <div class="container page-hero-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <span>Nuestra Academia</span>
      </nav>
      <h1>Nuestra <span class="hero-highlight">Academia</span></h1>
      <p>Más de 29 años formando estudiantes con excelencia académica y valores cristianos</p>
    </div>
  </section>

  <section class="history section-padding">
    <div class="container">
      <div class="section-heading">
        <span class="section-label">Historia</span>
        <h2 class="section-title">Nuestra Trayectoria</h2>
        <p class="section-desc">Un recorrido por los momentos más importantes de nuestra institución</p>
      </div>
      <div class="timeline">
        <div class="timeline-item reveal">
          <div class="timeline-dot"></div>
          <div class="timeline-content card">
            <span class="timeline-year">1995</span>
            <h3>Fundación</h3>
            <p>La Academia Cristiana Maranatha abre sus puertas con la visión de ofrecer una educación de excelencia fundamentada en principios cristianos en Nicaragua.</p>
          </div>
        </div>
        <div class="timeline-item reveal">
          <div class="timeline-dot"></div>
          <div class="timeline-content card">
            <span class="timeline-year">2005</span>
            <h3>Crecimiento y Expansión</h3>
            <p>Ampliamos nuestras instalaciones para recibir a más estudiantes y mejorar la infraestructura educativa, incluyendo laboratorios y áreas deportivas.</p>
          </div>
        </div>
        <div class="timeline-item reveal">
          <div class="timeline-dot"></div>
          <div class="timeline-content card">
            <span class="timeline-year">2012</span>
            <h3>Reconocimiento Académico</h3>
            <p>Somos reconocidos por el Ministerio de Educación por nuestros altos estándares académicos y nuestro compromiso con la formación integral.</p>
          </div>
        </div>
        <div class="timeline-item reveal">
          <div class="timeline-dot"></div>
          <div class="timeline-content card">
            <span class="timeline-year">2020</span>
            <h3>Innovación Educativa</h3>
            <p>Implementamos programas de inglés intensivo, tecnología educativa y formación en valores adaptados a los nuevos tiempos.</p>
          </div>
        </div>
        <div class="timeline-item reveal">
          <div class="timeline-dot"></div>
          <div class="timeline-content card">
            <span class="timeline-year">2026</span>
            <h3>Presente y Futuro</h3>
            <p>Continuamos creciendo y modernizándonos, manteniendo nuestro compromiso inquebrantable con la excelencia académica y la formación cristiana.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mission-vision section-padding">
    <div class="container">
      <div class="mv-grid">
        <div class="mv-card reveal card">
          <div class="mv-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Misión</h3>
          <p>Formar estudiantes con excelencia académica y valores cristianos, preparándolos para ser líderes que transformen su comunidad con fe, virtud, excelencia y patriotismo.</p>
        </div>
        <div class="mv-card reveal card">
          <div class="mv-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 22c4.418 0 8-4.486 8-10S16.418 2 12 2"/><path d="M2 12h20"/></svg>
          </div>
          <h3>Visión</h3>
          <p>Ser la institución educativa cristiana de referencia en Nicaragua, reconocida por la excelencia académica, la formación integral y el impacto positivo en la sociedad.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="values-detailed section-padding">
    <div class="container">
      <div class="section-heading">
        <span class="section-label">Valores</span>
        <h2 class="section-title">Nuestros Pilares</h2>
        <p class="section-desc">Los principios que guían cada aspecto de nuestra labor educativa</p>
      </div>
      <div class="values-grid">
        <div class="value-card reveal card">
          <div class="value-card-icon" style="background:var(--primary-glow);color:var(--primary)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3>Fe</h3>
          <p>Fundamos nuestra enseñanza en la palabra de Dios, guiando a cada estudiante a desarrollar una relación personal con Cristo.</p>
        </div>
        <div class="value-card reveal card">
          <div class="value-card-icon" style="background:var(--secondary-glow);color:var(--secondary-dark)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Virtud</h3>
          <p>Cultivamos la integridad moral y la rectitud en cada acción, formando estudiantes de carácter firme y principios sólidos.</p>
        </div>
        <div class="value-card reveal card">
          <div class="value-card-icon" style="background:var(--primary-glow);color:var(--primary)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          </div>
          <h3>Excelencia</h3>
          <p>Buscamos la gloria de Dios en todo, esforzándonos por alcanzar el más alto nivel académico y personal en cada área.</p>
        </div>
        <div class="value-card reveal card">
          <div class="value-card-icon" style="background:var(--secondary-glow);color:var(--secondary-dark)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Solidaridad</h3>
          <p>Fomentamos el amor al prójimo y el servicio a los demás, formando estudiantes sensibles a las necesidades de su comunidad.</p>
        </div>
        <div class="value-card reveal card">
          <div class="value-card-icon" style="background:var(--primary-glow);color:var(--primary)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Honestidad</h3>
          <p>Inculcamos la transparencia y la verdad como pilares fundamentales para la convivencia y el desarrollo personal.</p>
        </div>
        <div class="value-card reveal card">
          <div class="value-card-icon" style="background:var(--secondary-glow);color:var(--secondary-dark)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3>Patriotismo</h3>
          <p>Formamos estudiantes orgullosos de su identidad nicaragüense, comprometidos con el desarrollo y el bienestar de su país.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="team section-padding">
    <div class="container">
      <div class="section-heading">
        <span class="section-label">Equipo Directivo</span>
        <h2 class="section-title">Nuestro Liderazgo</h2>
        <p class="section-desc">Conoce a las personas que guían nuestra institución</p>
      </div>
      <div class="team-grid">
        <div class="team-card reveal card">
          <div class="team-photo">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80" alt="Director" loading="lazy" />
          </div>
          <div class="team-info">
            <h3>Lic. Juan Pérez</h3>
            <span class="team-role">Director General</span>
            <p>Más de 20 años de experiencia en liderazgo educativo.</p>
          </div>
        </div>
        <div class="team-card reveal card">
          <div class="team-photo">
            <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400&q=80" alt="Subdirectora" loading="lazy" />
          </div>
          <div class="team-info">
            <h3>MSc. María García</h3>
            <span class="team-role">Subdirectora Académica</span>
            <p>Especialista en currículo y evaluación educativa.</p>
          </div>
        </div>
        <div class="team-card reveal card">
          <div class="team-photo">
            <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&q=80" alt="Coordinador" loading="lazy" />
          </div>
          <div class="team-info">
            <h3>Lic. Carlos Mendoza</h3>
            <span class="team-role">Coordinador de Primaria</span>
            <p>Comprometido con la formación integral de los más pequeños.</p>
          </div>
        </div>
        <div class="team-card reveal card">
          <div class="team-photo">
            <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&q=80" alt="Coordinadora" loading="lazy" />
          </div>
          <div class="team-info">
            <h3>Lic. Ana Martínez</h3>
            <span class="team-role">Coordinadora de Secundaria</span>
            <p>Guiando a los adolescentes hacia la excelencia académica.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="facilities section-padding">
    <div class="container">
      <div class="section-heading">
        <span class="section-label">Instalaciones</span>
        <h2 class="section-title">Nuestros Espacios</h2>
        <p class="section-desc">Instalaciones diseñadas para el aprendizaje y el desarrollo integral</p>
      </div>
      <div class="facilities-grid">
        <div class="facility-card reveal">
          <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&q=80" alt="Aulas" loading="lazy" />
          <div class="facility-overlay">
            <h3>Aulas Modernas</h3>
            <p>Espacios ventilados e iluminados con recursos tecnológicos</p>
          </div>
        </div>
        <div class="facility-card reveal">
          <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=600&q=80" alt="Laboratorios" loading="lazy" />
          <div class="facility-overlay">
            <h3>Laboratorios</h3>
            <p>Equipados para ciencias, informática e inglés</p>
          </div>
        </div>
        <div class="facility-card reveal">
          <img src="https://images.unsplash.com/photo-1571902943202-507ec2618e8f?w=600&q=80" alt="Cancha" loading="lazy" />
          <div class="facility-overlay">
            <h3>Áreas Deportivas</h3>
            <p>Cancha multiusos y espacios recreativos</p>
          </div>
        </div>
        <div class="facility-card reveal">
          <img src="https://images.unsplash.com/photo-1525921429624-4793792221c0?w=600&q=80" alt="Capilla" loading="lazy" />
          <div class="facility-overlay">
            <h3>Capilla</h3>
            <p>Espacio para la formación espiritual y devocionales</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="accreditations section-padding">
    <div class="container">
      <div class="section-heading">
        <span class="section-label">Acreditaciones</span>
        <h2 class="section-title">Reconocimientos</h2>
        <p class="section-desc">Entidades que avalan nuestra calidad educativa</p>
      </div>
      <div class="accred-grid">
        <div class="accred-card card reveal">
          <div class="accred-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>MINED</h3>
          <p>Ministerio de Educación de Nicaragua</p>
        </div>
        <div class="accred-card card reveal">
          <div class="accred-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>CNU</h3>
          <p>Consejo Nacional de Universidades</p>
        </div>
        <div class="accred-card card reveal">
          <div class="accred-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          </div>
          <h3>Asociación de Colegios Cristianos</h3>
          <p>Miembro activo y certificado</p>
        </div>
      </div>
    </div>
  </section>

  <WhatsAppBtn />
</BaseLayout>

<style>
  .page-hero { background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?w=1400&q=80') center/cover no-repeat; }
  .hero-highlight { background: linear-gradient(135deg, var(--secondary-light), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .history { background: var(--bg); }
  .timeline { position: relative; max-width: 700px; margin: 0 auto; padding-left: 40px; }
  .timeline::before {
    content: ''; position: absolute; left: 15px; top: 0; bottom: 0;
    width: 2px; background: linear-gradient(to bottom, var(--secondary), var(--primary), var(--secondary));
  }
  .timeline-item { position: relative; margin-bottom: 32px; }
  .timeline-dot {
    position: absolute; left: -32px; top: 24px; width: 16px; height: 16px;
    border-radius: 50%; background: var(--secondary); border: 3px solid var(--bg); z-index: 1;
  }
  .timeline-content { padding: 24px; }
  .timeline-year {
    display: inline-block; padding: 4px 12px; background: var(--primary); color: white;
    font-size: 0.8rem; font-weight: 700; border-radius: var(--radius-full); margin-bottom: 8px;
  }
  .timeline-content h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 8px; color: var(--text); }
  .timeline-content p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.7; }

  .mission-vision { background: var(--bg-section); }
  .mv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
  .mv-card { padding: 36px; text-align: center; border-top: 3px solid var(--secondary); }
  .mv-icon {
    width: 56px; height: 56px; border-radius: 14px; background: var(--primary-glow);
    color: var(--primary); display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px; transition: all var(--transition);
  }
  .mv-card:hover .mv-icon { background: var(--primary); color: white; transform: scale(1.05); }
  .mv-card h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 12px; color: var(--text); }
  .mv-card p { font-size: 0.92rem; color: var(--text-secondary); line-height: 1.7; }

  .values-detailed { background: var(--bg); }
  .values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .value-card { padding: 28px 24px; text-align: center; }
  .value-card-icon {
    width: 52px; height: 52px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 14px; transition: all var(--transition);
  }
  .value-card:hover .value-card-icon { transform: scale(1.08); }
  .value-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: var(--text); }
  .value-card p { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.7; }

  .team { background: var(--bg-section); }
  .team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .team-card { overflow: hidden; text-align: center; }
  .team-photo { width: 120px; height: 120px; border-radius: 50%; overflow: hidden; margin: 24px auto 0; border: 3px solid var(--secondary); }
  .team-photo img { width: 100%; height: 100%; object-fit: cover; }
  .team-info { padding: 16px 20px 24px; }
  .team-info h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 4px; }
  .team-role { display: block; font-size: 0.8rem; color: var(--secondary); font-weight: 600; margin-bottom: 8px; }
  .team-info p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; }

  .facilities { background: var(--bg); }
  .facilities-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .facility-card { position: relative; border-radius: var(--radius); overflow: hidden; height: 260px; }
  .facility-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .facility-card:hover img { transform: scale(1.06); }
  .facility-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(transparent 40%, rgba(0,0,0,0.8));
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 24px; color: white;
  }
  .facility-overlay h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 4px; }
  .facility-overlay p { font-size: 0.85rem; opacity: 0.8; }

  .accreditations { background: var(--bg-section); }
  .accred-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .accred-card { padding: 32px 24px; text-align: center; }
  .accred-icon { color: var(--secondary); margin-bottom: 12px; }
  .accred-card h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .accred-card p { font-size: 0.85rem; color: var(--text-muted); }

  @media (max-width: 1024px) {
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .mv-grid { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: 1fr; }
    .facilities-grid { grid-template-columns: 1fr; }
    .accred-grid { grid-template-columns: 1fr; }
    .facility-card { height: 200px; }
  }
</style>
