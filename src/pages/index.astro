---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryCard from '../components/GalleryCard.astro';
import WhatsAppBtn from '../components/WhatsAppBtn.astro';
import { getGalleries } from '../lib/gallery';

const galleries = await getGalleries();
const latestGalleries = galleries.slice(0, 3);
---

<BaseLayout title="ACM - Academia Cristiana Maranatha">
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-bg-shape hero-bg-shape--1"></div>
      <div class="hero-bg-shape hero-bg-shape--2"></div>
      <div class="hero-bg-shape hero-bg-shape--3"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Bienvenidos a la ACM
      </div>
      <h1 class="hero-title">
        Academia Cristiana <br/><span class="hero-highlight">Maranatha</span>
      </h1>
      <p class="hero-subtitle">Formando líderes con excelencia académica y valores cristianos</p>
      <div class="hero-actions">
        <a href="#galerias" class="btn btn-secondary btn-lg">
          Ver Galerías
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/nosotros" class="btn btn-outline btn-lg hero-btn-outline">Conócenos</a>
      </div>
    </div>
    <div class="hero-wave">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,60 C360,120 1080,0 1440,60 L1440,120 L0,120 Z" fill="var(--bg)"/>
      </svg>
    </div>
  </section>

  <section class="features section-padding">
    <div class="container">
      <div class="features-grid">
        <div class="feature-card card">
          <div class="feature-icon-wrapper">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <h3>Galerías de Eventos</h3>
          <p>Revive los momentos especiales de nuestra comunidad educativa a través de nuestras galerías fotográficas.</p>
        </div>
        <div class="feature-card card">
          <div class="feature-icon-wrapper">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Excelencia Académica</h3>
          <p>Comprometidos con la formación integral de nuestros estudiantes desde preescolar hasta 8vo grado.</p>
        </div>
        <div class="feature-card card">
          <div class="feature-icon-wrapper">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3>Valores Cristianos</h3>
          <p>Fomentamos principios y valores que forman el carácter de nuestros alumnos para la vida.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="galerias" class="galleries section-padding">
    <div class="container">
      <div class="section-heading">
        <span class="section-label">Galerías</span>
        <h2 class="section-title">Galería de Eventos</h2>
        <p class="section-desc">Explora los momentos más importantes de nuestra comunidad educativa</p>
      </div>

      {galleries.length > 0 ? (
        <>
          <div class="gallery-grid">
            {latestGalleries.map(g => (
              <GalleryCard
                title={g.title}
                slug={g.slug}
                date={g.date}
                description={g.description}
                coverImage={g.coverImage}
                imageCount={g.images.length}
              />
            ))}
          </div>
          {galleries.length > 3 && (
            <div class="gallery-cta">
              <a href="/galerias" class="btn btn-primary">Ver Todas las Galerías</a>
            </div>
          )}
        </>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <h2>Pronto tendremos novedades</h2>
          <p>Estamos preparando contenido para ti. Vuelve pronto para ver nuestras galerías.</p>
        </div>
      )}
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-pattern"></div>
    <div class="container cta-content">
      <span class="cta-badge">Contacto</span>
      <h2>¿Tienes fotos de un evento?</h2>
      <p>Comparte con nosotros los momentos especiales de nuestros estudiantes.</p>
      <a href="/contacto" class="btn btn-secondary btn-lg">
        Contáctanos
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  <WhatsAppBtn />
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), url('/bg-acm.jpg') center/cover no-repeat;
    color: var(--text-on-primary);
    padding: 100px 0 0;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .hero-bg-shape {
    position: absolute;
    border-radius: 50%;
  }
  .hero-bg-shape--1 {
    top: -30%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(200,149,42,0.12) 0%, transparent 70%);
  }
  .hero-bg-shape--2 {
    bottom: -20%;
    left: -5%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 60%);
  }
  .hero-bg-shape--3 {
    top: 20%;
    left: 40%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(200,149,42,0.06) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding: 40px 0 70px;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.85);
    padding: 8px 20px;
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    font-weight: 500;
    margin-bottom: 28px;
    letter-spacing: 0.3px;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 900;
    margin-bottom: 16px;
    line-height: 1.1;
    letter-spacing: -1px;
  }
  .hero-highlight {
    background: linear-gradient(135deg, var(--secondary-light), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    opacity: 0.8;
    font-weight: 400;
    max-width: 560px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero-btn-outline {
    border-color: rgba(255,255,255,0.35) !important;
    color: white !important;
  }
  .hero-btn-outline:hover {
    border-color: white !important;
    background: rgba(255,255,255,0.1) !important;
    transform: translateY(-2px);
  }

  .hero-wave {
    line-height: 0;
    margin-bottom: -2px;
  }
  .hero-wave svg {
    width: 100%;
    height: 80px;
    display: block;
  }

  .features {
    background: var(--bg);
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .feature-card {
    padding: 36px 28px;
    text-align: center;
    border-top: 3px solid var(--primary);
    position: relative;
  }
  .feature-icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--primary-glow);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    transition: all var(--transition);
  }
  .feature-card:hover .feature-icon-wrapper {
    background: var(--primary);
    color: white;
    transform: scale(1.05);
  }
  .feature-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
  }
  .feature-card p {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .galleries {
    background: var(--bg-section);
  }
  .section-heading {
    text-align: center;
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .section-heading .section-title { margin-bottom: 8px; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .gallery-cta {
    text-align: center;
    margin-top: 36px;
  }

  .cta-section {
    background: linear-gradient(135deg, var(--primary) 0%, #4a0e0e 100%);
    color: var(--text-on-primary);
    padding: 72px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 25% 50%, rgba(200,149,42,0.08) 0%, transparent 50%),
      radial-gradient(circle at 75% 50%, rgba(255,255,255,0.03) 0%, transparent 50%);
  }
  .cta-content { position: relative; z-index: 1; }
  .cta-badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--secondary-light);
    margin-bottom: 12px;
  }
  .cta-content h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  .cta-content p {
    font-size: 1.1rem;
    opacity: 0.85;
    margin-bottom: 28px;
    max-width: 450px;
    margin-left: auto;
    margin-right: auto;
  }

  .empty-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .hero { padding: 60px 0 0; }
    .hero-title { font-size: 2.2rem; }
    .hero-content { padding: 24px 0 40px; }
    .hero-wave svg { height: 40px; }
    .features-grid { grid-template-columns: 1fr; gap: 20px; }
    .gallery-grid { grid-template-columns: 1fr; gap: 16px; }
    .cta-content h2 { font-size: 1.5rem; }
    .cta-section { padding: 48px 0; }
  }
</style>


