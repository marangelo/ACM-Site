---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import { getGallery } from '../../lib/gallery';

const { slug } = Astro.params;
const gallery = await getGallery(slug);

if (!gallery) {
  return Astro.redirect('/');
}

const formatDate = new Date(gallery.date).toLocaleDateString('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<BaseLayout title={`${gallery.title} - ACM Galería`}>
  <div class="container" style="padding-top:32px;padding-bottom:48px">
    <a href="/" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Volver a galerías
    </a>

    <header class="gallery-header">
      <h1 class="gallery-title">{gallery.title}</h1>
      <div class="gallery-meta">
        <span class="gallery-date">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {formatDate}
        </span>
        <span class="gallery-count">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          {gallery.images.length} {gallery.images.length === 1 ? 'foto' : 'fotos'}
        </span>
      </div>
      {gallery.description && (
        <p class="gallery-desc">{gallery.description}</p>
      )}
    </header>

    <PhotoGrid images={gallery.images} slug={slug} />
  </div>
</BaseLayout>

<style>
  .gallery-header { margin-bottom: 32px; }
  .gallery-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 12px;
    color: var(--text);
    letter-spacing: -0.3px;
  }
  .gallery-meta {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .gallery-date, .gallery-count {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .gallery-date { color: var(--secondary); font-weight: 600; }
  .gallery-desc {
    font-size: 1.02rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: auto;
  }

  @media (max-width: 768px) {
    .gallery-title { font-size: 1.5rem; }
  }
</style>
