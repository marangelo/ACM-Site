---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto - ACM" description="Comunícate con la Academia Cristiana Maranatha en Nicaragua. Información de contacto, mapa, redes sociales y datos de pago.">
  <section class="page-hero">
    <div class="container page-hero-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <span>Contacto</span>
      </nav>
      <h1>Contacto</h1>
      <p>Estaremos encantados de escucharte</p>
    </div>
  </section>

  <section class="container section-padding">
    <div class="contact-grid">
      <div class="contact-info">
        <span class="section-label">Información</span>
        <h2 class="section-title" style="margin-bottom:32px">Ponte en contacto</h2>

        <div class="contact-items">
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="contact-item-label">Dirección</span>
              <span class="contact-item-value">Managua, Nicaragua</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div>
              <span class="contact-item-label">Teléfono</span>
              <span class="contact-item-value">(505) 0000-0000</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <span class="contact-item-label">Email</span>
              <span class="contact-item-value">info@acm.edu.ni</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <span class="contact-item-label">Horario</span>
              <span class="contact-item-value">Lun - Vie: 7:00 AM - 1:00 PM</span>
              <span class="contact-item-value" style="opacity:0.6">Sáb: 8:00 AM - 12:00 PM</span>
            </div>
          </div>
        </div>

        <div class="contact-social" style="margin-top:32px">
          <span class="contact-item-label" style="margin-bottom:12px;display:block">Redes Sociales</span>
          <div class="social-row">
            <a href="https://facebook.com/acmnicaragua" class="social-btn" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://instagram.com/acmnicaragua" class="social-btn" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://wa.me/50500000000" class="social-btn" aria-label="WhatsApp" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href="https://youtube.com/@acmnicaragua" class="social-btn" aria-label="YouTube" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          </div>
        </div>

        <div class="map-container" style="margin-top:32px;border-radius:var(--radius-sm);overflow:hidden">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3900.5!2d-86.2!3d12.1!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTLCsDA2JzAwLjAiTiA4NsKwMTInMDAuMCJX!5e0!3m2!1ses!2sni!4v1" width="100%" height="250" style="border:0" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Ubicación ACM"></iframe>
        </div>
      </div>

      <div class="contact-form-wrapper">
        <div class="contact-form card">
          <h3 class="form-heading">Envíanos un Mensaje</h3>
          <form id="contact-form" class="form">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Nombre completo *</label>
                <input type="text" id="name" name="name" class="form-input" required placeholder="Tu nombre" />
              </div>
              <div class="form-group">
                <label for="email">Correo electrónico *</label>
                <input type="email" id="email" name="email" class="form-input" required placeholder="tu@email.com" />
              </div>
            </div>
            <div class="form-group">
              <label for="phone">Teléfono (opcional)</label>
              <input type="tel" id="phone" name="phone" class="form-input" placeholder="(505) 0000-0000" />
            </div>
            <div class="form-group">
              <label for="message">Mensaje *</label>
              <textarea id="message" name="message" class="form-input" required rows="5" placeholder="Escribe tu mensaje aquí..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center">
              Enviar Mensaje
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>
          <div id="form-success" class="message message-success" style="display:none;margin-top:20px">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:6px"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            ¡Mensaje enviado con éxito! Te contactaremos pronto.
          </div>
        </div>

        <div class="contact-form card" style="margin-top:24px">
          <h3 class="form-heading">Pagos y Transferencias</h3>
          <div class="payment-info">
            <div class="payment-row">
              <span class="payment-label">Banco</span>
              <span class="payment-value">Banco de Nicaragua</span>
            </div>
            <div class="payment-row">
              <span class="payment-label">Titular</span>
              <span class="payment-value">Academia Cristiana Maranatha</span>
            </div>
            <div class="payment-row">
              <span class="payment-label">Cuenta Corriente</span>
              <span class="payment-value">C$ 000-000-000-0</span>
            </div>
            <div class="payment-row">
              <span class="payment-label">Número de Referencia</span>
              <span class="payment-value">000-000-000-000-00</span>
            </div>
            <div style="margin-top:16px;font-size:0.85rem;color:var(--text-secondary);line-height:1.6">
              <p>Para pagos por transferencia, por favor envía el comprobante a <strong>info@acm.edu.ni</strong> indicando el nombre del estudiante y el concepto del pago.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const required = form.querySelectorAll('[required]');
        let valid = true;
        required.forEach(f => { if (!f.value.trim()) valid = false; });
        if (valid) {
          document.getElementById('form-success').style.display = 'block';
          form.reset();
        } else {
          alert('Por favor completa todos los campos requeridos.');
        }
      });
    }
  });
</script>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 48px; align-items: start; }
  .contact-items { display: flex; flex-direction: column; gap: 24px; }
  .contact-item { display: flex; gap: 16px; align-items: flex-start; }
  .contact-item-icon { width: 48px; height: 48px; border-radius: 12px; background: var(--primary-glow); color: var(--primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
  .contact-item-label { display: block; font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 2px; }
  .contact-item-value { display: block; font-size: 0.95rem; color: var(--text); font-weight: 500; line-height: 1.5; }
  .social-row { display: flex; gap: 8px; }
  .social-btn { width: 44px; height: 44px; border-radius: 12px; background: var(--primary-glow); color: var(--primary); display: flex; align-items: center; justify-content: center; transition: all var(--transition); }
  .social-btn:hover { background: var(--primary); color: white; transform: translateY(-2px); }
  .contact-form { padding: 36px; }
  .form-heading { font-size: 1.3rem; font-weight: 700; margin-bottom: 24px; color: var(--text); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .payment-info { display: flex; flex-direction: column; gap: 0; }
  .payment-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border-light); font-size: 0.9rem; }
  .payment-label { color: var(--text-muted); font-weight: 500; }
  .payment-value { color: var(--text); font-weight: 600; }
  .payment-row:last-child { border-bottom: none; }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 32px; }
    .form-row { grid-template-columns: 1fr; }
    .contact-form { padding: 24px; }
  }
</style>
