---
const { size = 42, showSubtitle = true } = Astro.props;
const iconSize = size;
const fontSize = size * 0.38;
---

<a href="/" class="logo">
  <div class="logo-icon" style={`width:${iconSize}px;height:${iconSize}px`}>
    <span class="logo-acm" style={`font-size:${fontSize}px`}>ACM</span>
  </div>
  {showSubtitle && (
    <div class="logo-text">
      <span class="logo-name">Academia Cristiana Maranatha</span>
      <span class="logo-sub">Galería de Eventos</span>
    </div>
  )}
</a>

<style>
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  .logo-icon {
    background: linear-gradient(135deg, var(--primary) 0%, #4a0e0e 100%);
    border: 2px solid var(--secondary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .logo-acm {
    font-weight: 900;
    color: var(--secondary-light);
    letter-spacing: 1px;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .logo-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.2px;
  }
  .logo-sub {
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 500;
  }
</style>
