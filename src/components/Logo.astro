---
const { size = 150, showSubtitle = true } = Astro.props;
---

<a href="/" class="logo">
  <img src="/logo.png" alt="ACM" class="logo-img" style={`width:${size}px;height:${size}px`} />
  
</a>

<style>
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  .logo-img {
    object-fit: contain;
    border-radius: 8px;
    flex-shrink: 0;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .logo-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.2px;
  }
  .logo-sub {
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 500;
  }
</style>
