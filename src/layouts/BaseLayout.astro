---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = 'ACM - Academia Cristiana Maranatha' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="description" content="Galería de eventos de la Academia Cristiana Maranatha" />
</head>
<body>
  <Header />
  <main class="main">
    <slot />
  </main>
  <Footer />
</body>
</html>

<style>
  .main {
    flex: 1;
  }
</style>
